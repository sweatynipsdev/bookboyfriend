ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
MINIMAX_API_KEY=your_key_here
MINIMAX_GROUP_ID=your_group_id_here

STT_PROVIDER=whisper_api
TTS_PROVIDER=minimax
LLM_PROVIDER=minimax
EMBEDDING_PROVIDER=sentence_transformers

# MiniMax model options: MiniMax-M2.5, MiniMax-M2.5-highspeed, MiniMax-M2.1, MiniMax-M2
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_TTS_MODEL=speech-02-hd
MINIMAX_TTS_VOICE=female-shaonv

DB_PATH=bookboyfriend.db
CHROMA_PATH=./characters_db
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# JWT Authentication
JWT_SECRET=change-me-to-a-random-string
